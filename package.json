    "generate": "node bin/generate.mjs",
    "server": "node bin/server.mjs",
    "build-t42": "node bin/build-t42.mjs"
  },
  "bin": {
    "retrocable-teletext-generate": "bin/generate.mjs",
    "retrocable-teletext-server": "bin/server.mjs",
    "retrocable-teletext-build-t42": "bin/build-t42.mjs"
  },
  "license": "ISC",
  "dependencies": {
    "@iptv/playlist": "^1.2.1",
    "@iptv/xmltv": "^1.0.1"
  }
}
